NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# MongoDB Atlas - crie um novo cluster em mongodb.com
MONGODB_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/pink-pig

# Payload CMS - gere uma string aleatória forte
PAYLOAD_SECRET=TROQUE_ISSO_POR_UM_SECRET_ALEATORIO_FORTE

# Resend - https://resend.com
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM_EMAIL=noreply@seudominio.com

# Stripe - https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx

# Crie um Price no Stripe para a taxa de transação ($1.00)
STRIPE_TRANSACTION_FEE_PRICE_ID=price_xxxxxxxxxx

# Google OAuth - https://console.cloud.google.com/apis/credentials
# 1. Crie um OAuth 2.0 Client ID (tipo: Web application)
# 2. Adicione a Authorized redirect URI:
#    Local: http://localhost:3000/api/auth/google/callback
#    Produção: https://seudominio.com/api/auth/google/callback
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret

# ─── Tenant / White-label ────────────────────────────────────────────────────
# Todas as variáveis abaixo têm fallbacks sensatos. Configure apenas as que
# diferem do padrão.

# Nome da loja — aparece na navbar, footer, emails e painel /admin
NEXT_PUBLIC_STORE_NAME="My Digital Store"

# Tagline curta para redes sociais / meta tags
NEXT_PUBLIC_STORE_TAGLINE="High-quality digital products."

# Descrição longa (usada em meta description padrão)
NEXT_PUBLIC_STORE_DESCRIPTION="Welcome to our store. Every product is verified by our team."

# Email de suporte ao cliente
NEXT_PUBLIC_SUPPORT_EMAIL="support@example.com"

# Moeda ISO 4217 (ex: USD, EUR, BRL). Afeta formatação de preços e Stripe.
# ATENÇÃO: a moeda do Stripe é definida na criação do produto e não pode ser alterada.
NEXT_PUBLIC_CURRENCY="USD"

# Cor primária da marca em hex — injetada via CSS custom property --color-brand
NEXT_PUBLIC_PRIMARY_COLOR="#ec4899"

# URL pública do logo (ex: https://seudominio.com/logo.png)
# Se vazio, o ícone inline padrão será usado.
NEXT_PUBLIC_LOGO_URL=""

# Texto e URL do link "Built by" no footer. Deixe vazio para ocultar o link.
NEXT_PUBLIC_COPYRIGHT_OWNER="My Digital Store"
NEXT_PUBLIC_COPYRIGHT_URL=""

# Handle do Twitter/X (sem @) — usado em meta tags
NEXT_PUBLIC_TWITTER_HANDLE=""

# Categorias de produto em JSON (se vazio, gerencie via /admin > Categories)
# Exemplo:
# NEXT_PUBLIC_PRODUCT_CATEGORIES='[{"label":"E-books","value":"ebooks","featured":[{"name":"New","href":"/products?category=ebooks","imageSrc":""}]}]'
NEXT_PUBLIC_PRODUCT_CATEGORIES=""
